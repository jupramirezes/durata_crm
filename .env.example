# Supabase project URL (NOT the dashboard URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Supabase anonymous key (safe to commit, RLS protects data)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: credentials used by scripts/ to sign in and bypass RLS.
# REQUIRED if you plan to run `npm run migrate`, `scripts/seed-producto.ts`,
# `scripts/check-counts.ts`, or `scripts/corregir-fechas.ts`.
# Do NOT commit real values — copy this file to .env (which is in .gitignore).
MIGRATION_AUTH_EMAIL=your-user@example.com
MIGRATION_AUTH_PASS=your-password-here
